rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function userIdMatchesAuth() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can update their own profile (except role)
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'role',
                      'stravaTokens',
                      'stravaConnected',
                      'stravaAthleteId',
                      'stravaAthleteName',
                      'stravaLastSync'
                    ]);
      // Admin can read/write all user profiles
      allow read, write: if request.auth != null && isAdmin();
      // Allow create for new users (self-registration on first login)
      // SECURITY: block role escalation — users cannot set role to admin on create
      allow create: if request.auth != null && request.auth.uid == userId
                    && (!('role' in request.resource.data.keys()) || request.resource.data.role == 'user');
    }

    // Workouts collection
    match /workouts/{workoutId} {
      // Users can only read/write their own workouts (by userId field)
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if userIdMatchesAuth();
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      // Admin can read all
      allow read: if request.auth != null && isAdmin();
    }

    // Measurements collection
    match /measurements/{measurementId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if userIdMatchesAuth();
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && isAdmin();
    }

    // Training plans (doc ID = userId)
    match /training_plans/{planUserId} {
      // Users can read their own plan
      allow read: if request.auth != null && request.auth.uid == planUserId;
      // Users can write their own plan
      allow write: if request.auth != null && request.auth.uid == planUserId;
      // Admin can read/write all plans
      allow read, write: if request.auth != null && isAdmin();
    }

    // Strava activities (future)
    match /strava_activities/{activityId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      // Only Cloud Functions can write
      allow write: if false;
      allow read: if request.auth != null && isAdmin();
    }

    // Weekly summaries
    match /weekly_summaries/{summaryId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      // Admin can read/write all
      allow read, write: if request.auth != null && isAdmin();
    }

    // Chat messages (per-user, Firestore-persisted)
    match /chat_messages/{messageId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if false;
      // Admin can read all
      allow read: if request.auth != null && isAdmin();
    }

    // Plan cycles (training plan history)
    match /plan_cycles/{cycleId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if userIdMatchesAuth();
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && isAdmin();
    }

    // Private Strava credentials — Cloud Functions only
    match /strava_connections/{userId} {
      allow read, write: if false;
    }

    // AI usage tracking (written only by Cloud Functions)
    match /ai_usage/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }

    // chat_conversations — REMOVED (AI Chat feature removed in v6.7.0)
  }
}
