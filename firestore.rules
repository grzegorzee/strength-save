rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function userIdMatchesAuth() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    function keepsOwner() {
      return request.resource.data.userId == resource.data.userId;
    }

    function hasSelfAccess(userId) {
      return request.auth != null
             && request.auth.uid == userId
             && exists(/databases/$(database)/documents/users/$(userId))
             // Brak pola status (konta z logowania Google / sprzed hardeningu) = traktuj jak aktywny.
             // Jawnie nieaktywni (pending_verification, suspended) nadal zablokowani.
             && (
               !('status' in get(/databases/$(database)/documents/users/$(userId)).data)
               || get(/databases/$(database)/documents/users/$(userId)).data.status == 'active'
             )
             && (
               !('access' in get(/databases/$(database)/documents/users/$(userId)).data)
               || !('enabled' in get(/databases/$(database)/documents/users/$(userId)).data.access)
               || get(/databases/$(database)/documents/users/$(userId)).data.access.enabled != false
             );
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      // Klient może zmieniać wyłącznie preferencje i dane prezentacyjne. Wszystkie
      // uprawnienia, statusy i tokeny są własnością zaufanego backendu.
      // Typy wartości (Z41): walidacja na merged dokumencie — pole obecne musi mieć
      // właściwy typ, brak pola jest OK (lekcja ef8b8d5/880cb9e).
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'displayName', 'photoURL', 'language', 'preferences',
                      'notificationPrefs', 'onboardingCompleted', 'onboarding',
                      'trainingProfile'
                    ])
                    && (!('displayName' in request.resource.data)
                        || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 200))
                    && (!('photoURL' in request.resource.data)
                        || (request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 1000))
                    && (!('language' in request.resource.data)
                        || (request.resource.data.language is string && request.resource.data.language.size() <= 10))
                    && (!('preferences' in request.resource.data) || request.resource.data.preferences is map)
                    && (!('notificationPrefs' in request.resource.data) || request.resource.data.notificationPrefs is map)
                    && (!('onboardingCompleted' in request.resource.data) || request.resource.data.onboardingCompleted is bool)
                    && (!('onboarding' in request.resource.data) || request.resource.data.onboarding is map)
                    && (!('trainingProfile' in request.resource.data) || request.resource.data.trainingProfile is map);
      // Admin can read/write all user profiles
      allow read, write: if request.auth != null && isAdmin();
      // Profile creation happens through Cloud Functions
      allow create: if false;
    }

    // Zamknięty schemat dokumentu treningu — user może zapisywać we WŁASNYCH
    // dokumentach tylko znane pola (audyt 4.3: koszty/integralność, nie cross-user).
    // Per-exercise notes są clampowane w kodzie (rules nie iterują po tablicach).
    function validWorkoutShape() {
      // createdAt: pole legacy (dokumenty sprzed schematu Z28) — bez niego update
      // takiego treningu pada PERMISSION_DENIED (hasOnly widzi CAŁY dokument po merge).
      return request.resource.data.keys().hasOnly([
        'id', 'userId', 'dayId', 'date', 'exercises', 'completed', 'completedAt',
        'notes', 'cycleId', 'skippedExercises', 'dayName', 'dayFocus',
        'durationSec', 'startedAt', 'updatedAt', 'revision', 'lastWriteId', 'createdAt'
      ])
      && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string && request.resource.data.notes.size() <= 5000));
    }

    // Workouts collection
    match /workouts/{workoutId} {
      // Users can only read/write their own workouts (by userId field).
      // resource == null: dokument nie istnieje — get() po ID zwraca pustkę, nic nie wycieka.
      // Bez tego getDoc na nowym (jeszcze nieutworzonym) treningu = PERMISSION_DENIED i nie da się
      // rozpocząć treningu (resource.data.userId na nieistniejącym dokumencie to błąd ewaluacji).
      allow read: if request.auth != null
                  && (isAdmin() || resource == null || hasSelfAccess(resource.data.userId));
      allow create: if userIdMatchesAuth() && hasSelfAccess(request.resource.data.userId) && validWorkoutShape();
      allow update: if request.auth != null
                    && hasSelfAccess(resource.data.userId)
                    && keepsOwner()
                    && validWorkoutShape();
      allow delete: if request.auth != null
                    && hasSelfAccess(resource.data.userId);
      // Admin can read all
      allow read: if request.auth != null && isAdmin();
    }

    // Zamknięty schemat pomiaru (Z41): znane pola liczbowe + identyfikatory.
    function validMeasurementShape() {
      return request.resource.data.keys().hasOnly([
        'id', 'userId', 'date', 'weight', 'armLeft', 'armRight', 'chest', 'waist',
        'hips', 'thighLeft', 'thighRight', 'calfLeft', 'calfRight'
      ])
      && (request.resource.data.date is string && request.resource.data.date.size() <= 10)
      && (!('weight' in request.resource.data) || request.resource.data.weight is number)
      && (!('armLeft' in request.resource.data) || request.resource.data.armLeft is number)
      && (!('armRight' in request.resource.data) || request.resource.data.armRight is number)
      && (!('chest' in request.resource.data) || request.resource.data.chest is number)
      && (!('waist' in request.resource.data) || request.resource.data.waist is number)
      && (!('hips' in request.resource.data) || request.resource.data.hips is number)
      && (!('thighLeft' in request.resource.data) || request.resource.data.thighLeft is number)
      && (!('thighRight' in request.resource.data) || request.resource.data.thighRight is number)
      && (!('calfLeft' in request.resource.data) || request.resource.data.calfLeft is number)
      && (!('calfRight' in request.resource.data) || request.resource.data.calfRight is number);
    }

    // Measurements collection
    match /measurements/{measurementId} {
      allow read: if request.auth != null
                  && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow create: if userIdMatchesAuth() && hasSelfAccess(request.resource.data.userId) && validMeasurementShape();
      allow update: if request.auth != null
                    && hasSelfAccess(resource.data.userId)
                    && keepsOwner()
                    && validMeasurementShape();
      allow delete: if request.auth != null
                    && hasSelfAccess(resource.data.userId);
      allow read: if request.auth != null && isAdmin();
    }

    // Zamknięty schemat planu (Z41). Głęboka walidacja days (tygodnie/dni/ćwiczenia)
    // zostaje w kodzie — rules nie iterują po tablicach.
    function validTrainingPlanShape() {
      return request.resource.data.keys().hasOnly([
        'days', 'durationWeeks', 'startDate', 'updatedAt', 'revision'
      ])
      && (!('days' in request.resource.data) || request.resource.data.days is list)
      && (!('durationWeeks' in request.resource.data) || request.resource.data.durationWeeks is number)
      && (!('startDate' in request.resource.data)
          || (request.resource.data.startDate is string && request.resource.data.startDate.size() <= 10))
      && (!('updatedAt' in request.resource.data)
          || (request.resource.data.updatedAt is string && request.resource.data.updatedAt.size() <= 40))
      && (!('revision' in request.resource.data) || request.resource.data.revision is number);
    }

    // Training plans (doc ID = userId)
    match /training_plans/{planUserId} {
      // Users can read their own plan
      allow read: if request.auth != null && (isAdmin() || hasSelfAccess(planUserId));
      // Users can write their own plan
      allow write: if request.auth != null && hasSelfAccess(planUserId) && validTrainingPlanShape();
      // Admin can read/write all plans
      allow read, write: if request.auth != null && isAdmin();
    }

    // Strava activities (future)
    match /strava_activities/{activityId} {
      allow read: if request.auth != null
                  && (isAdmin() || hasSelfAccess(resource.data.userId));
      // Only Cloud Functions can write
      allow write: if false;
      allow read: if request.auth != null && isAdmin();
    }

    // Weekly summaries: klient TYLKO czyta (generator AI usunięty w Z39; functions
    // nie zapisują wcale — martwe create/update zamknięte, Z41/R2-15).
    match /weekly_summaries/{summaryId} {
      allow read: if request.auth != null
                  && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow create, update: if false;
      // Admin can read/write all
      allow read, write: if request.auth != null && isAdmin();
    }

    // Chat messages: feature AI Chat usunięty w v6.7.0 — jedynym writerem jest
    // admin SDK w Functions (omija rules). Klient nie tworzy nowych wpisów.
    match /chat_messages/{messageId} {
      allow read: if request.auth != null && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow create: if false;
      // Delete zamknięte spójnie z create (Z41/R2-15): GDPR kasuje przez admin SDK.
      allow delete: if false;
      allow update: if false;
      // Admin can read all
      allow read: if request.auth != null && isAdmin();
    }

    // Zamknięty schemat cyklu (Z41). Głęboka walidacja days zostaje w kodzie.
    function validPlanCycleShape() {
      return request.resource.data.keys().hasOnly([
        'userId', 'days', 'durationWeeks', 'startDate', 'endDate', 'status',
        'createdAt', 'stats', 'technical', 'hiddenFromInsights'
      ])
      && (!('days' in request.resource.data) || request.resource.data.days is list)
      && (!('durationWeeks' in request.resource.data) || request.resource.data.durationWeeks is number)
      && (!('startDate' in request.resource.data)
          || (request.resource.data.startDate is string && request.resource.data.startDate.size() <= 10))
      && (!('endDate' in request.resource.data)
          || (request.resource.data.endDate is string && request.resource.data.endDate.size() <= 10))
      && (!('status' in request.resource.data)
          || (request.resource.data.status is string && request.resource.data.status.size() <= 20))
      && (!('createdAt' in request.resource.data)
          || (request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 40))
      && (!('stats' in request.resource.data) || request.resource.data.stats is map)
      && (!('technical' in request.resource.data) || request.resource.data.technical is bool)
      && (!('hiddenFromInsights' in request.resource.data) || request.resource.data.hiddenFromInsights is bool);
    }

    // Plan cycles (training plan history)
    match /plan_cycles/{cycleId} {
      // resource == null: getCycleById po nieistniejącym ID nie wycieka danych (patrz workouts).
      allow read: if request.auth != null && (isAdmin() || resource == null || hasSelfAccess(resource.data.userId));
      allow create: if userIdMatchesAuth() && hasSelfAccess(request.resource.data.userId) && validPlanCycleShape();
      allow update: if request.auth != null
                    && hasSelfAccess(resource.data.userId)
                    && keepsOwner()
                    && validPlanCycleShape();
      allow delete: if request.auth != null && hasSelfAccess(resource.data.userId);
      allow read: if request.auth != null && isAdmin();
    }

    // Zamknięty schemat operacji merge (Z41).
    function validCycleOperationShape() {
      return request.resource.data.keys().hasOnly([
        'userId', 'kind', 'primaryCycleId', 'restCycleIds', 'workoutIds',
        'newStart', 'newEnd', 'newDuration', 'phase', 'nextWorkoutIndex', 'nextCycleIndex'
      ])
      && (!('kind' in request.resource.data)
          || (request.resource.data.kind is string && request.resource.data.kind.size() <= 30))
      && (!('primaryCycleId' in request.resource.data)
          || (request.resource.data.primaryCycleId is string && request.resource.data.primaryCycleId.size() <= 200))
      && (!('restCycleIds' in request.resource.data) || request.resource.data.restCycleIds is list)
      && (!('workoutIds' in request.resource.data) || request.resource.data.workoutIds is list)
      && (!('newStart' in request.resource.data)
          || (request.resource.data.newStart is string && request.resource.data.newStart.size() <= 10))
      && (!('newEnd' in request.resource.data)
          || (request.resource.data.newEnd is string && request.resource.data.newEnd.size() <= 10))
      && (!('newDuration' in request.resource.data) || request.resource.data.newDuration is number)
      && (!('phase' in request.resource.data)
          || (request.resource.data.phase is string && request.resource.data.phase.size() <= 30))
      && (!('nextWorkoutIndex' in request.resource.data) || request.resource.data.nextWorkoutIndex is number)
      && (!('nextCycleIndex' in request.resource.data) || request.resource.data.nextCycleIndex is number);
    }

    // Checkpoints for client-side, resumable cycle merges. They are private to the
    // owner and carry no authority beyond remapping that owner's own documents.
    match /plan_cycle_operations/{operationId} {
      allow read: if request.auth != null
                  && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow create: if userIdMatchesAuth() && hasSelfAccess(request.resource.data.userId) && validCycleOperationShape();
      allow update: if request.auth != null
                    && hasSelfAccess(resource.data.userId)
                    && keepsOwner()
                    && validCycleOperationShape();
      allow delete: if request.auth != null && hasSelfAccess(resource.data.userId);
      allow read, write: if request.auth != null && isAdmin();
    }

    // Private Strava credentials — Cloud Functions only
    match /strava_connections/{userId} {
      allow read, write: if false;
    }

    // AI usage tracking (written only by Cloud Functions)
    match /ai_usage/{docId} {
      allow read: if request.auth != null && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }

    // Private API keys and logs — Cloud Functions only
    match /api_keys/{keyId} {
      allow read, write: if false;
    }

    match /api_audit_logs/{logId} {
      allow read, write: if false;
    }

    match /api_rate_limits/{docId} {
      allow read, write: if false;
    }

    match /email_verification_codes/{docId} {
      allow read, write: if false;
    }

    match /invites/{inviteId} {
      allow read, write: if false;
    }

    match /waitlist_entries/{entryId} {
      allow read, write: if false;
    }

    match /auth_audit_logs/{logId} {
      allow read, write: if false;
    }

    match /notification_logs/{logId} {
      allow read, write: if false;
    }

    // Zamknięty schemat telemetrii (Z41). Dokumenty legacy mają PŁASKIE klucze
    // "counters.xxx" (historyczny zapis dot-notation) — hasOnly musi je dopuszczać,
    // inaczej merge na takim dokumencie pada (lekcja createdAt z workouts).
    function validTelemetryShape() {
      return request.resource.data.keys().hasOnly([
        'userId', 'date', 'updatedAt', 'counters',
        'counters.draft_recovered', 'counters.local_save_failed', 'counters.sync_success'
      ])
      && (request.resource.data.date is string && request.resource.data.date.size() <= 10)
      && (!('updatedAt' in request.resource.data)
          || (request.resource.data.updatedAt is string && request.resource.data.updatedAt.size() <= 40))
      && (!('counters' in request.resource.data) || request.resource.data.counters is map);
    }

    match /app_telemetry_daily/{docId} {
      allow read: if request.auth != null
                  && (isAdmin() || hasSelfAccess(resource.data.userId));
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && hasSelfAccess(request.resource.data.userId)
                    && validTelemetryShape();
      allow update: if request.auth != null
                    && hasSelfAccess(resource.data.userId)
                    && keepsOwner()
                    && validTelemetryShape();
      allow delete: if false;
      allow read: if request.auth != null && isAdmin();
    }

    // Rejestr błędów produkcyjnych klienta (append-only): user tworzy własne
    // wpisy, czyta wyłącznie admin. Pełny schemat + widełki createdAt (Z41/R2-13):
    // flood nieopłacalny, klienckie createdAt nie zasłoni realnych błędów w panelu.
    // Create świadomie bez hasSelfAccess: telemetria ma działać też przy problemach
    // z profilem; koszt get() w rules > zysk. expiresAt opcjonalne: klienty
    // build <= 48 raportują bez TTL (pole doszło w Z40).
    match /client_errors/{errorId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'code', 'phase', 'detail', 'sessionHash', 'appVersion', 'platform', 'createdAt', 'expiresAt'])
        && request.resource.data.code is string
        && request.resource.data.code.size() <= 64
        && request.resource.data.phase is string
        && request.resource.data.phase.size() <= 32
        && request.resource.data.detail is string
        && request.resource.data.detail.size() <= 500
        && (!('sessionHash' in request.resource.data)
            || (request.resource.data.sessionHash is string && request.resource.data.sessionHash.size() == 8))
        && request.resource.data.appVersion is string
        && request.resource.data.appVersion.size() <= 32
        && request.resource.data.platform in ['web', 'ios', 'android']
        && request.resource.data.createdAt is int
        && request.resource.data.createdAt >= request.time.toMillis() - 10 * 60 * 1000
        && request.resource.data.createdAt <= request.time.toMillis() + 10 * 60 * 1000
        && (!('expiresAt' in request.resource.data) || request.resource.data.expiresAt is timestamp);
      allow read: if request.auth != null && isAdmin();
      allow update, delete: if false;
    }

    // Globalne flagi funkcji — każdy zalogowany czyta, tylko admin zapisuje.
    // Zawężone do feature_flags: przyszłe dokumenty configu nie wyciekają domyślnie.
    match /config/feature_flags {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // chat_conversations — REMOVED (AI Chat feature removed in v6.7.0)
  }
}
