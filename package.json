{
  "name": "strength-save",
  "private": true,
  "version": "6.13.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "build:mobile": "vite build --mode mobile",
    "build:dev": "vite build --mode development",
    "mobile:sync": "npm run build:mobile && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "release:ios": "scripts/release-ios.sh",
    "preflight:ios-release": "node scripts/release-ios-preflight.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "preflight:jdk21": "node scripts/require-jdk21.mjs",
    "preflight:webkit": "node scripts/require-playwright-webkit.mjs",
    "test:rules": "npm run preflight:jdk21 && firebase emulators:exec --only firestore --project rules-repro \"node scripts/test-firestore-rules.mjs\"",
    "test:functions:emulator": "npm run preflight:jdk21 && firebase emulators:exec --only auth,firestore --project functions-m1-repro \"npm --prefix functions test -- registration.integration\"",
    "prebuild": "npm run typecheck",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "e2e": "npm run e2e:mock",
    "e2e:mock": "playwright test --project=chromium",
    "e2e:webkit": "npm run preflight:webkit && playwright test --project=webkit e2e/critical.spec.ts",
    "e2e:emulator": "npm run preflight:jdk21 && firebase emulators:exec --only auth,firestore --project fittracker-workouts \"playwright test --config playwright.emulator.config.ts\"",
    "ios:simulator:smoke": "bash scripts/ios-simulator-smoke.sh",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@revenuecat/purchases-capacitor": "^13.1.6",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "firebase": "^12.8.0",
    "html2canvas-pro": "^2.0.2",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.32.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  }
}
